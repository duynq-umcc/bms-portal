rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isManager() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isTechnician() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician';
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isPrivileged() {
      return isAdmin() || isManager() || isTechnician();
    }

    function canReadAll() {
      return isAuthenticated();
    }

    // Users — authenticated can read, admin can write, user can update own doc (FCM tokens)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['lastLogin', 'fcmTokens', 'updatedAt']));
    }

    // Audit log — admin only
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Work Orders — all roles can write
    match /workOrders/{orderId} {
      allow read: if canReadAll();
      allow write: if isAdmin() || isManager() || isTechnician();
    }

    // Incidents — admin, manager can write
    match /incidents/{incidentId} {
      allow read: if canReadAll();
      allow write: if isAdmin() || isManager();
    }

    // Vendors — admin, manager can write
    match /vendors/{vendorId} {
      allow read: if canReadAll();
      allow write: if isAdmin() || isManager();
    }

    // All other collections — admin only
    match /org/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /infra/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /fireSafety/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /civilProjects/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /medicalDevices/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /compliance/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /warehouse/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isManager();
    }

    match /inventory/{docId}/transactions/{txId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isManager() || isTechnician();
      allow update, delete: if isAdmin() || isManager();
    }

    match /inventoryTransactions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isManager() || isTechnician();
      allow update: if isAuthenticated()
        && (getUserRole() in ['admin', 'manager']
            || (getUserRole() == 'technician'
                && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['legalDocs', 'legalDocsComplete', 'legalDocsStatus'])));
      allow delete: if getUserRole() in ['admin'];
    }

    match /importDocAudit/{auditId} {
      allow read: if isAuthenticated()
        && getUserRole() in ['admin', 'manager'];
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /assets/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /environment/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /reports/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Maintenance schedule — admin only
    match /maintenanceSchedule/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Fire drills — admin only
    match /fireDrills/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Periodic inspections — admin only
    match /periodicInspections/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Civil work logs — admin only
    match /civilWorkLogs/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Calibration schedules — admin only
    match /calibrationSchedules/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Legal documents — admin only
    match /legalDocuments/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Energy/water readings — admin only
    match /energyReadings/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /waterReadings/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    match /waterAlerts/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Waste log — admin only
    match /wasteLog/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Building inspections — admin only
    match /buildingInspections/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Vendor ratings — admin only
    match /vendorRatings/{docId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Subcollections — device service history
    match /medicalDevices/{deviceId}/serviceHistory/{recordId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Asset disposals
    match /assets/{assetId}/disposals/{recordId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Vendor contracts
    match /vendors/{vendorId}/contracts/{contractId} {
      allow read: if canReadAll();
      allow write: if isAdmin();
    }

    // Notifications — user can only read/write their own
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Expiry Alerts
    match /expiryAlerts/{alertId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated()
        && getUserRole() in ['admin', 'manager', 'technician'];
      allow delete: if getUserRole() in ['admin', 'manager'];
    }

    // Alert Rules — authenticated can read, admin can write
    match /alertRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // PM Schedules
    match /pmSchedules/{schedId} {
      allow read: if isAuthenticated();
      allow create, update: if getUserRole() in ['admin', 'manager'];
      allow delete: if getUserRole() == 'admin';
    }

    // PM Work Orders
    match /pmWorkOrders/{woId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.assignedTo
            || getUserRole() in ['admin', 'manager']);
      allow delete: if getUserRole() in ['admin'];
    }

    // PM Execution Log
    match /pmExecutionLog/{logId} {
      allow read: if getUserRole() in ['admin', 'manager'];
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Operation logs — M&E daily shift logs
    match /operationLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.loggedBy
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']);
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Disposal Requests (P2.2)
    match /disposalRequests/{reqId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && getUserRole() in ['admin', 'manager', 'technician'];
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.requestedBy
            || getUserRole() in ['admin', 'manager']);
      allow delete: if getUserRole() == 'admin'
        && resource.data.status == 'draft';
    }

    // Disposal Councils (P2.2)
    match /disposalCouncils/{councilId} {
      allow read: if isAuthenticated();
      allow create, update: if getUserRole() in ['admin', 'manager'];
      allow delete: if getUserRole() == 'admin';

      match /votes/{voteId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated()
          && getUserRole() in ['admin', 'manager'];
      }
    }

    // Disposal Executions (P2.2)
    match /disposalExecutions/{execId} {
      allow read: if isAuthenticated();
      allow create, update: if getUserRole() in ['admin', 'manager'];
      allow delete: if false;
    }
  }
}
