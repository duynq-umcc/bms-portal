rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isManager() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isTechnician() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician';
    }

    function isPrivileged() {
      return isAdmin() || isManager() || isTechnician();
    }

    // P1.1: Owner-or-privileged check — resource owner or any privileged role
    // QW-6: Used to restrict technician read access to only their own records
    function isOwnerOrPrivileged() {
      return isPrivileged()
        || resource.data.uid == request.auth.uid
        || resource.data.assignedTo == request.auth.uid
        || resource.data.createdBy == request.auth.uid
        || resource.data.loggedBy == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      // Users can only update own FCM tokens / lastLogin, not their role
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['lastLogin', 'fcmTokens', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ── Audit Log ─────────────────────────────────────────────────

    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Work Orders ───────────────────────────────────────────────
    // P1.1: Technicians can ONLY update status/notes/completedAt/technicianId
    //       Managers create/update any field. Admins can delete.
    //       Technicians can READ only their own WOs (created/assigned).

    match /workOrders/{orderId} {
      allow read: if isOwnerOrPrivileged();
      allow create: if isManager();
      allow update: if isManager()
        || (isTechnician()
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'notes', 'completedAt', 'technicianId']));
      allow delete: if isAdmin();
    }

    // ── Incidents ─────────────────────────────────────────────────
    // Technicians can create (report), managers approve/resolve

    match /incidents/{incidentId} {
      allow read: if isPrivileged();
      allow create: if isTechnician();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Vendors ───────────────────────────────────────────────────

    match /vendors/{vendorId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Org / Infra / Fire Safety / Civil Projects ────────────────

    match /org/{docId} {
      allow read: if isPrivileged();
      allow write: if isManager();
    }

    match /infra/{docId} {
      allow read: if isPrivileged();
      allow write: if isManager();
    }

    match /fireSafety/{docId} {
      allow read: if isPrivileged();
      allow write: if isManager();
    }

    match /civilProjects/{docId} {
      allow read: if isPrivileged();
      allow write: if isManager();
    }

    // ── Medical Devices ───────────────────────────────────────────

    match /medicalDevices/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Subcollection: service history
    match /medicalDevices/{deviceId}/serviceHistory/{recordId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Compliance ────────────────────────────────────────────────

    match /compliance/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Warehouse & Inventory ─────────────────────────────────────

    match /warehouse/{docId} {
      allow read: if isPrivileged();
      allow write: if isManager();
    }

    match /inventory/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    match /inventory/{docId}/transactions/{txId} {
      allow read: if isPrivileged();
      allow create: if isPrivileged();
      allow update, delete: if isManager();
    }

    match /inventoryTransactions/{docId} {
      allow read: if isPrivileged();
      allow create: if isPrivileged();
      // Technicians can only update legal-docs fields on their own tx
      allow update: if isManager()
        || (isTechnician()
            && request.auth.uid == resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['legalDocs', 'legalDocsComplete', 'legalDocsStatus']));
      allow delete: if isAdmin();
    }

    // ── Import Doc Audit ──────────────────────────────────────────

    match /importDocAudit/{auditId} {
      allow read: if isManager();
      allow create: if isPrivileged();
      allow update, delete: if false;
    }

    // ── Assets ─────────────────────────────────────────────────────

    match /assets/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Subcollection: asset disposals
    match /assets/{assetId}/disposals/{recordId} {
      allow read: if isManager();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Environment ───────────────────────────────────────────────

    match /environment/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────────
    // P1.1: Only managers/admins can read KPI reports; technicians excluded

    match /reports/{docId} {
      allow read: if isAdmin() || isManager();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Maintenance Schedule ──────────────────────────────────────

    match /maintenanceSchedule/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Fire Drills ───────────────────────────────────────────────

    match /fireDrills/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Periodic Inspections ──────────────────────────────────────

    match /periodicInspections/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Civil Work Logs ───────────────────────────────────────────

    match /civilWorkLogs/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Calibration Schedules ─────────────────────────────────────

    match /calibrationSchedules/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Legal Documents ───────────────────────────────────────────

    match /legalDocuments/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Energy / Water Readings ───────────────────────────────────

    match /energyReadings/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isPrivileged();
      allow delete: if isManager();
    }

    match /waterReadings/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isPrivileged();
      allow delete: if isManager();
    }

    match /waterAlerts/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isPrivileged();
      allow delete: if isManager();
    }

    // ── Waste Log ─────────────────────────────────────────────────

    match /wasteLog/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Building Inspections ──────────────────────────────────────

    match /buildingInspections/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Vendor Ratings ────────────────────────────────────────────

    match /vendorRatings/{docId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Vendor Contracts (subcollection) ─────────────────────────

    match /vendors/{vendorId}/contracts/{contractId} {
      allow read: if isManager();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Notifications ──────────────────────────────────────────────
    // Users can only read/write their own notifications

    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Expiry Alerts ─────────────────────────────────────────────

    match /expiryAlerts/{alertId} {
      allow read: if isPrivileged();
      allow create, update: if isPrivileged();
      allow delete: if isManager();
    }

    // ── Alert Rules ───────────────────────────────────────────────

    match /alertRules/{ruleId} {
      allow read: if isPrivileged();
      allow write: if isAdmin();
    }

    // ── PM Schedules ──────────────────────────────────────────────

    match /pmSchedules/{schedId} {
      allow read: if isPrivileged();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── PM Work Orders ─────────────────────────────────────────────
    // QW-2: Managers create; technicians can only update their own assigned work

    match /pmWorkOrders/{woId} {
      allow read: if isPrivileged();
      allow create: if isManager();
      allow update: if isManager()
        || (isTechnician() && request.auth.uid == resource.data.assignedTo);
      allow delete: if isAdmin();
    }

    // ── PM Execution Log ───────────────────────────────────────────
    // QW-3: Managers read; technicians can create execution records

    match /pmExecutionLog/{logId} {
      allow read: if isManager();
      allow create: if isTechnician();
      allow update, delete: if false;
    }

    // ── Operation Logs (M&E daily shift logs) ──────────────────────

    match /operationLogs/{logId} {
      allow read: if isPrivileged();
      allow create: if isPrivileged();
      allow update: if isManager()
        || (isTechnician() && request.auth.uid == resource.data.loggedBy);
      allow delete: if isAdmin();
    }

    // ── Disposal Requests ──────────────────────────────────────────
    // QW-4: Only managers can create/update; technicians can read their own

    match /disposalRequests/{reqId} {
      allow read: if isManager()
        || (isTechnician() && request.auth.uid == resource.data.requestedBy);
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // ── Disposal Councils ─────────────────────────────────────────

    match /disposalCouncils/{councilId} {
      allow read: if isManager();
      allow create, update: if isManager();
      allow delete: if isAdmin();

      match /votes/{voteId} {
        allow read: if isManager();
        allow create, update: if isManager();
      }
    }

    // ── Disposal Executions ────────────────────────────────────────

    match /disposalExecutions/{execId} {
      allow read: if isManager();
      allow create, update: if isManager();
      allow delete: if false;
    }

    // ── Technician KPI ──────────────────────────────────────────────
    // P1.1: Technicians can only read/update their own KPI doc (uid == docId)

    match /technicianKpi/{uid} {
      allow read: if isManager() || (isTechnician() && request.auth.uid == uid);
      allow write: if isManager()
        || (isTechnician() && request.auth.uid == uid);
    }

    // ── KPI History ────────────────────────────────────────────────

    match /kpiHistory/{uid} {
      allow read: if isPrivileged();
      allow write: if isManager();

      match /months/{period} {
        allow read: if isPrivileged();
        allow write: if isManager();
      }
    }

    // ── DEFAULT DENY — Catch-all ──────────────────────────────────
    // QW-5: Replaces the old wildcard match /{docId} that gave read-all

    match /{document=**} {
      allow read, write: if false;
    }
  }
}