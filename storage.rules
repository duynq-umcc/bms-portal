rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /documents/imports/{importId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
             'application/pdf|image/jpeg|image/png|image/webp'
           );
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    match /documents/compliance/{docId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    match /pm/workorders/{woId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    // Disposal request attachments (P2.2)
    match /disposal/requests/{reqId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    // Disposal council documents (P2.2)
    match /disposal/councils/{councilId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager']
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    // P2.5: Radiation permit documents
    match /radiation/permits/{permitId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

    // P2.5: Calibration certificates
    match /calibration/certs/{scheduleId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role in ['admin', 'manager'];
    }

  }
}
